# --- SEGURANÇA ---
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,your-cloudrun-url.run.app

# --- SITE ---
SITE_NAME=Vendas Links Tops ML
SITE_DESCRIPTION=As melhores ofertas e produtos do Mercado Livre com links afiliados.
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# --- GOOGLE ADSENSE ---
GOOGLE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# --- BANCO DE DADOS ---
# Para desenvolvimento local (SQLite):
USE_SQLITE=True
DATABASE_URL=sqlite:///db.sqlite3

# Para produção com Cloud SQL (MySQL):
# USE_SQLITE=False
# DB_NAME=vendas_db
# DB_USER=root
# DB_PASSWORD=your-secure-password
# DB_HOST=cloudsql-instance.c.your-project.internal
# DB_SOCKET=/cloudsql/your-project:region:instance

# --- GCP CLOUD STORAGE (PRODUÇÃO) ---
GS_PROJECT_ID=your-gcp-project-id
GS_BUCKET_NAME=your-gcs-bucket-name
GS_QUERYSTRING_AUTH=True

# --- CLOUD SCHEDULER (AUTOMAÇÃO) ---
CRON_SECRET=your-secret-for-cloud-scheduler

# --- DEBUG GCP (Se tiver erros 500) ---
# GS_QUERYSTRING_AUTH=False  # Para testar se a falha é na assinatura da URL

