# ============================================================================
# VENDAS LINKS TOPS ML - Configuração de Ambiente
# ============================================================================
# Este arquivo serve como referência. Copie para .env e preencha os valores
# cp .env.example .env
# ============================================================================

# --- SEGURANÇA E DJANGO ---
SECRET_KEY=django-insecure-seu-secret-key-aqui-mude-em-producao
DEBUG=True
# Nota: NÃO incluir portas aqui (Django gerencia isso internamente)
# Exemplo dev: localhost,127.0.0.1
# Exemplo prod: seu-app.run.app,www.seu-dominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# --- SITE CUSTOMIZAÇÕES ---
SITE_NAME=SITE_NAME
SITE_DESCRIPTION=SITE_DESCRIPTION
DEFAULT_FROM_EMAIL=DEFAULT_FROM_EMAIL
GOOGLE_ADSENSE_ID=GOOGLE_ADSENSE_ID



# Para produção com Cloud SQL (MySQL) - descomente e configure:
USE_SQLITE=USE_SQLITE
DB_NAME=DB_NAME
DB_USER=DB_USER
DB_PASSWORD=DB_PASSWORD
DB_HOST=DB_HOST
DB_SOCKET=DB_SOCKET

# --- GCP CLOUD STORAGE (PRODUÇÃO APENAS) ---
# Deixe em branco para desenvolvimento local
GS_PROJECT_ID=GS_PROJECT_ID
GS_BUCKET_NAME=GS_BUCKET_NAME

# --- CLOUD SCHEDULER (AUTOMAÇÃO) ---
# Chave secreta para validar requisições do Cloud Scheduler
CRON_SECRET=CRON_SECRET

